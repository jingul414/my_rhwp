{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rhwp-desktop",
  "version": "0.1.0",
  "identifier": "com.jingul.rhwp-desktop",
  "build": {
    "beforeDevCommand": "wasm-pack build src-rhwp --target web --dev && npm --prefix src-rhwp/rhwp-studio install && npm --prefix src-rhwp/rhwp-studio run dev",
    "devUrl": "http://localhost:7700",
    "beforeBuildCommand": "[ \"${CI}\" = \"true\" ] || wasm-pack build src-rhwp --target web && npm --prefix src-rhwp/rhwp-studio install && npm --prefix src-rhwp/rhwp-studio run build",
    "frontendDist": "../src-rhwp/rhwp-studio/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["hwp", "hwpx"],
        "name": "HWP Document",
        "description": "HWP/HWPX 문서",
        "mimeType": "application/x-hwp"
      }
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/mime/packages/rhwp-desktop.xml": "deb/rhwp-desktop-mime.xml"
        }
      }
    }
  }
}
